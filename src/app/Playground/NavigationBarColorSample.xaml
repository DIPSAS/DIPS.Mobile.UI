<?xml version="1.0" encoding="utf-8"?>

<dui:ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:dui="http://dips.com/mobile.ui"
                 x:Class="Playground.NavigationBarColorSample"
                 Title="Navigation bar color"
                 Padding="{dui:Sizes size_4}">
    <dui:ContentPage.ToolbarItems>
        <ToolbarItem Text="Close"
                     Clicked="OnCloseClicked" />
    </dui:ContentPage.ToolbarItems>

    <dui:ScrollView>
        <dui:VerticalStackLayout Spacing="{dui:Sizes size_3}">
            <dui:Label Text="Navigation bar color"
                       Style="{dui:Styles Label=SectionHeader}" />
            <dui:Label Text="This modal sets NavigationPage.BarBackgroundColor to Black and inherits title and toolbar item colors from Shell."
                       Style="{dui:Styles Label=UI200}"
                       TextColor="{dui:Colors color_text_subtle}" />
            <Grid HeightRequest="{dui:Sizes size_12}"
                  BackgroundColor="Black" />
            <dui:ListItem Title="Background color"
                          Subtitle="Black" />
            <dui:ListItem Title="Text color"
                          Subtitle="Inherited from Shell" />
        </dui:VerticalStackLayout>
    </dui:ScrollView>
</dui:ContentPage>