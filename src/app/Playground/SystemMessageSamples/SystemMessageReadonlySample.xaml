<?xml version="1.0" encoding="utf-8"?>

<dui:ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:dui="http://dips.com/mobile.ui"
                 x:Class="Playground.SystemMessageSamples.SystemMessageReadonlySample"
                 Padding="{dui:Sizes page_margin_medium}"
                 Title="SystemMessage readonly">
    <dui:VerticalStackLayout Spacing="{dui:Sizes content_margin_small}">
        <dui:Button Text="readonly"
                    Style="{dui:Styles Button=DefaultLarge}"
                    Clicked="ShowReadonlySystemMessage" />
        <dui:Button Text="normal modus"
                    Style="{dui:Styles Button=DefaultLarge}"
                    Clicked="ShowNormalModeSystemMessage" />
    </dui:VerticalStackLayout>
</dui:ContentPage>