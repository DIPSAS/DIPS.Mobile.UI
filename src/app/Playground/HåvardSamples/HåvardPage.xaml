<?xml
    version="1.0"
    encoding="utf-8"?>

<dui:ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:dui="http://dips.com/mobile.ui"
                 xmlns:håvardSamples="clr-namespace:Playground.HåvardSamples"
                 xmlns:controls="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
                 x:Class="Playground.HåvardSamples.HåvardPage"
                 Padding="0">
    <dui:ContentPage.BindingContext>
        <håvardSamples:HåvardPageViewModel />
    </dui:ContentPage.BindingContext>
    <dui:ProSegmentedControl HorizontalOptions="Center"
                             Margin="10"
                             VerticalOptions="Start"
                             SegmentChanged="ProSegmentedControl_OnSegmentChanged">
        <dui:ProSegmentedControl.Segments>
            <x:Array Type="{x:Type x:String}">
                <x:String>Friday</x:String>
                <x:String>Saturday</x:String>
                <x:String>Sunday</x:String>
            </x:Array>
        </dui:ProSegmentedControl.Segments>
    </dui:ProSegmentedControl>

</dui:ContentPage>