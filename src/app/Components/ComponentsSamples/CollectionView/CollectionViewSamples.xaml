<?xml version="1.0" encoding="utf-8"?>

<dui:ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:dui="http://dips.com/mobile.ui"
                 xmlns:helpers="clr-namespace:Components.Helpers"
                 xmlns:collectionView="clr-namespace:Components.ComponentsSamples.CollectionView"
                 x:Class="Components.ComponentsSamples.CollectionView.CollectionViewSamples"
                 Title="CollectionView">

    <dui:VerticalStackLayout Spacing="0">
        <dui:NavigationListItem Title="Flat CollectionView"
                                Command="{helpers:NavigationCommand {x:Type collectionView:FlatCollectionViewSample}}"
                                HasBottomDivider="True"/>
        <dui:NavigationListItem Title="Grouped CollectionView"
                                Command="{helpers:NavigationCommand {x:Type collectionView:GroupedCollectionViewSample}}"/>
    </dui:VerticalStackLayout>

</dui:ContentPage>
