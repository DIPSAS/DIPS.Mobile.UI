<?xml version="1.0" encoding="utf-8"?>

<dui:ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:dui="http://dips.com/mobile.ui"
                 x:Class="Components.ComponentsSamples.Lists.ListsSamples"
                 Title="Lists">
    <dui:VerticalStackLayout Spacing="{dui:Sizes size_2}"
                             Padding="{dui:Thickness size_3}">
        <dui:NavigationListItem Title="CollectionView"
                                Command="{Binding NavigateToCollectionViewCommand}" />
        <dui:NavigationListItem Title="ScrollView"
                                Command="{Binding NavigateToScrollViewCommand}" />
    </dui:VerticalStackLayout>
</dui:ContentPage>
