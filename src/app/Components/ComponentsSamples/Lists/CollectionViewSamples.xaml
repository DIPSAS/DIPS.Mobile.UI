<?xml version="1.0" encoding="utf-8"?>

<dui:ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:dui="http://dips.com/mobile.ui"
                 x:Class="Components.ComponentsSamples.Lists.CollectionViewSamples"
                 Title="CollectionView"
                 HideSoftInputOnTapped="True">
    <Grid RowDefinitions="Auto, *">
        
        <!-- SearchBar outside CollectionView to test keyboard dismiss on scroll -->
        <dui:SearchBar Grid.Row="0"
                       Placeholder="Search items..."
                       Margin="{dui:Thickness Left=size_3, Right=size_3, Top=size_2}" />

        <dui:CollectionView Grid.Row="1"
                            ItemsSource="{Binding Items}"
                            RemoveFocusOnScroll="True">
            <dui:CollectionView.Header>
                <VerticalStackLayout>
                    <!-- SearchBar inside CollectionView header -->
                    <dui:SearchBar Placeholder="Search in header..."
                                   Margin="{dui:Thickness Left=size_3, Right=size_3, Top=size_2, Bottom=size_2}" />
                </VerticalStackLayout>
            </dui:CollectionView.Header>
            <dui:CollectionView.ItemTemplate>
                <DataTemplate>
                    <dui:ListItem Title="{Binding .}" />
                </DataTemplate>
            </dui:CollectionView.ItemTemplate>
        </dui:CollectionView>
    </Grid>
</dui:ContentPage>
