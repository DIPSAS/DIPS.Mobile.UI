<?xml version="1.0" encoding="utf-8"?>

<dui:ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:dui="http://dips.com/mobile.ui"
                 x:Class="Components.ComponentsSamples.Lists.ScrollViewSamples"
                 Title="ScrollView"
                 HideSoftInputOnTapped="True">
    <Grid RowDefinitions="Auto, *">

        <!-- SearchBar outside ScrollView to test keyboard dismiss on scroll -->
        <dui:SearchBar Grid.Row="0"
                       Placeholder="Search above scroll..."
                       Margin="{dui:Thickness Left=size_3, Right=size_3, Top=size_2}" />

        <dui:ScrollView Grid.Row="1"
                        RemoveFocusOnScroll="True"
                        HasAdditionalSpaceAtTheEnd="False">
            <dui:VerticalStackLayout Spacing="{dui:Sizes size_1}"
                                     Padding="{dui:Thickness size_3}">

                <!-- SearchBar inside ScrollView content (header position) -->
                <dui:SearchBar Placeholder="Search in scroll header..."
                               Margin="{dui:Thickness Bottom=size_2}" />

                <dui:ListItem Title="Item 1" />
                <dui:ListItem Title="Item 2" />
                <dui:ListItem Title="Item 3" />
                <dui:ListItem Title="Item 4" />
                <dui:ListItem Title="Item 5" />
                <dui:ListItem Title="Item 6" />
                <dui:ListItem Title="Item 7" />
                <dui:ListItem Title="Item 8" />
                <dui:ListItem Title="Item 9" />
                <dui:ListItem Title="Item 10" />
                <dui:ListItem Title="Item 11" />
                <dui:ListItem Title="Item 12" />
                <dui:ListItem Title="Item 13" />
                <dui:ListItem Title="Item 14" />
                <dui:ListItem Title="Item 15" />
                <dui:ListItem Title="Item 16" />
                <dui:ListItem Title="Item 17" />
                <dui:ListItem Title="Item 18" />
                <dui:ListItem Title="Item 19" />
                <dui:ListItem Title="Item 20" />
                <dui:ListItem Title="Item 21" />
                <dui:ListItem Title="Item 22" />
                <dui:ListItem Title="Item 23" />
                <dui:ListItem Title="Item 24" />
                <dui:ListItem Title="Item 25" />
            </dui:VerticalStackLayout>
        </dui:ScrollView>
    </Grid>
</dui:ContentPage>
