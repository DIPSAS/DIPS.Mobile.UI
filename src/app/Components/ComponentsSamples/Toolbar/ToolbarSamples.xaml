<?xml
    version="1.0"
    encoding="utf-8"?>

<dui:ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:dui="http://dips.com/mobile.ui"
                 xmlns:local="clr-namespace:Components.ComponentsSamples.Toolbar"
                 x:DataType="local:ToolbarSamplesViewModel"
                 x:Class="Components.ComponentsSamples.Toolbar.ToolbarSamples"
                 Title="Toolbar"
                 >

    <dui:ContentPage.BindingContext>
        <local:ToolbarSamplesViewModel />
    </dui:ContentPage.BindingContext>

    <dui:ContentPage.ToolbarItems>
        <ToolbarItem Text="Close" Clicked="OnCloseClicked" />
    </dui:ContentPage.ToolbarItems>

    <dui:ContentPage.BottomToolbar>
        <dui:Toolbar HorizontalAlignment="Start">
            <dui:ToolbarGroup>
                <dui:ToolbarButton Title="Signer"
                                   Command="{Binding EditCommand}" />
            </dui:ToolbarGroup>
            <dui:ToolbarGroup>
                <dui:ToolbarButton Icon="{dui:Icons edit_line}"
                                   Command="{Binding EditCommand}" />
                <dui:ToolbarButton Icon="{dui:Icons tab_more_fill}"
                                   Title="More actions">
                    <dui:ToolbarButton.Menu>
                        <dui:ContextMenu>
                            <dui:ContextMenuItem Title="Copy"
                                                 Command="{Binding CopyCommand}" />
                            <dui:ContextMenuItem Title="Delete"
                                                 Command="{Binding DeleteCommand}" />
                            <dui:ContextMenuItem Title="Share"
                                                 Command="{Binding ShareCommand}" />
                            <dui:ContextMenuItem Title="Print"
                                                 Command="{Binding PrintCommand}" />
                        </dui:ContextMenu>
                    </dui:ToolbarButton.Menu>
                </dui:ToolbarButton>
            </dui:ToolbarGroup>
        </dui:Toolbar>
    </dui:ContentPage.BottomToolbar>

    <dui:ScrollView Padding="{dui:Sizes size_4}" >
        <dui:VerticalStackLayout Spacing="8">
            <dui:Label Text="Bottom Toolbar"
                       Style="{dui:Styles Label=SectionHeader}" />
            <dui:Label
                Text="This toolbar has two groups: a text button and an icon group with a context menu. It is always compact and aligned to the end."
                Style="{dui:Styles Label=UI200}" />

            <dui:Label Text="Last action"
                       Style="{dui:Styles Label=SectionHeader}"
                       Margin="{dui:Thickness Top=size_4}" />
            <dui:Label Text="{Binding LastAction}"
                       Style="{dui:Styles Label=UI200}" />

            <Border HeightRequest="80" BackgroundColor="Red" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Red block" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="Orange" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Orange block" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="Gold" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Gold block" TextColor="Black" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="Green" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Green block" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="DodgerBlue" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Blue block" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="Red" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Red block" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="Orange" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Orange block" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="Gold" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Gold block" TextColor="Black" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="Green" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Green block" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="DodgerBlue" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Blue block" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="Red" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Red block" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="80" BackgroundColor="Orange" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Orange block" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
            <Border HeightRequest="120" Margin="0,0,0,80" BackgroundColor="Gold" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <Label Text="Gold block" TextColor="Black" VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
        </dui:VerticalStackLayout>
    </dui:ScrollView>

</dui:ContentPage>